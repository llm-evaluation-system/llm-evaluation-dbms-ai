# ── Database ──────────────────────────────────────────────────────────────────
# Primary application database (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/llm_evaluator

# Synchronous URL for Alembic migrations
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/llm_evaluator

# Sandboxed test database for SQL execution harness
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/llm_evaluator_test

# ── LLM API Keys ──────────────────────────────────────────────────────────────
# OpenAI — used for GPT-4o (challenger + judge)
OPENAI_API_KEY=sk-...

# Anthropic — used for Claude 3.5 Sonnet (challenger)
ANTHROPIC_API_KEY=sk-ant-...

# Google — used for Gemini 1.5 Pro (challenger)
GOOGLE_API_KEY=AIza...

# Groq — used for Llama 3.1 70B (challenger)
GROQ_API_KEY=gsk_...

# ── Task Queue ────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Question Bank ─────────────────────────────────────────────────────────────
QUESTION_BANK_PATH=/mnt/project/Database_Project_EVALUATIONGroup_4.xlsx
